# ============================================================
# Trading 212 Portfolio Monitor — configuration template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is already in .gitignore).
# ============================================================


# ────────────────────────────────────────────────────────────
# Trading 212 API
# T212 gives you two values when you generate a key:
#   "API Key"    → TRADING212_API_KEY
#   "Secret Key" → TRADING212_API_SECRET
# Both are required. They are combined as key:secret,
# Base64-encoded, and sent as HTTP Basic Auth on every request.
# ────────────────────────────────────────────────────────────

TRADING212_API_KEY=your_api_key_here
TRADING212_API_SECRET=your_secret_key_here

# Set to "true" to use your Demo (paper trading) account.
# Set to "false" when you are ready to connect to your Live account.
TRADING212_DEMO=true


# ────────────────────────────────────────────────────────────
# Email (Gmail)
# Sender and recipient can be the same address.
#
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create one named e.g. "Trading Monitor"
#   4. Paste the 16-char code below — no spaces
# ────────────────────────────────────────────────────────────

EMAIL_SENDER=your.gmail@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_RECIPIENT=your.inbox@example.com


# ────────────────────────────────────────────────────────────
# Report schedule (24-hour HH:MM, local machine time)
# ────────────────────────────────────────────────────────────

LONDON_OPEN_REPORT_TIME=08:05
US_OPEN_REPORT_TIME=14:35


# ────────────────────────────────────────────────────────────
# Alert thresholds
# ────────────────────────────────────────────────────────────

CHECK_INTERVAL_MINUTES=30
CHANGE_ALERT_THRESHOLD=6.0
STOCK_MOVE_THRESHOLD=6.0
